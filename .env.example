# ===== ComfyUI =====
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_TIMEOUT=300
COMFYUI_OUTPUT_DIR=./outputs

# ===== LLM（用于 Agent 推理）=====
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ===== 存储（可选，Phase 2 接入）=====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/visionflow
QDRANT_URL=http://localhost:6333

# ===== 应用 =====
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
