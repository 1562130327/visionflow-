{
 "1": {
  "class_type": "CheckpointLoaderSimple",
  "inputs": {
   "ckpt_name": "flux1-dev.safetensors"
  }
 },
 "2": {
  "class_type": "CLIPTextEncode",
  "inputs": {
   "text": "{{PROMPT}}, professional product photography, studio lighting, clean white background, commercial quality, 8k, sharp focus",
   "clip": ["1", 1]
  }
 },
 "3": {
  "class_type": "CLIPTextEncode",
  "inputs": {
   "text": "low quality, blurry, distorted, messy background, watermark",
   "clip": ["1", 1]
  }
 },
 "4": {
  "class_type": "EmptyLatentImage",
  "inputs": {
   "width": "{{WIDTH}}",
   "height": "{{HEIGHT}}",
   "batch_size": 1
  }
 },
 "5": {
  "class_type": "KSampler",
  "inputs": {
   "seed": "{{SEED}}",
   "steps": 30,
   "cfg": 5.0,
   "sampler_name": "euler",
   "scheduler": "normal",
   "denoise": 1.0,
   "model": ["1", 0],
   "positive": ["2", 0],
   "negative": ["3", 0],
   "latent_image": ["4", 0]
  }
 },
 "6": {
  "class_type": "VAEDecode",
  "inputs": {
   "samples": ["5", 0],
   "vae": ["1", 2]
  }
 },
 "7": {
  "class_type": "SaveImage",
  "inputs": {
   "filename_prefix": "visionflow_product",
   "images": ["6", 0]
  }
 }
}
